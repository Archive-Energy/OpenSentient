# ── Rivet ─────────────────────────────────────────────────────────────
RIVET_TOKEN=
RIVET_PROJECT_ID=

# ── Inference Keys ─────────────────────────────────────────────────────
# Resolved automatically by provider name in sentient.jsonc models block.
#   provider: "anthropic"  → ANTHROPIC_API_KEY
#   provider: "openrouter" → OPENROUTER_API_KEY
#   provider: "openai"     → OPENAI_API_KEY

ANTHROPIC_API_KEY=           # models.actor — Anthropic direct
                             # https://console.anthropic.com → API keys

OPENROUTER_API_KEY=          # models.embedding — OpenRouter
                             # https://openrouter.ai → API keys
                             # default model: baai/bge-m3

# ── Fixed Infrastructure ────────────────────────────────────────────────
# Sandbox: Daytona
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=          # your Daytona server URL

# Ingest: Parallel (Task API + Monitor API)
PARALLEL_API_KEY=
PARALLEL_WEBHOOK_SECRET=

# Auth: Unkey (optional — required for public API)
UNKEY_ROOT_KEY=

# ── Telegram ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # @BotFather → /newbot

# ── GitHub (optional) ──────────────────────────────────────────────────
GITHUB_TOKEN=                # fine-grained PAT for PR creation

# ── Parse.bot (optional) ───────────────────────────────────────────────
PARSE_API_KEY=               # parse.bot API key for skill creation

# ── Payments (x402 — optional) ─────────────────────────────────────────
STRIPE_CONNECTED_ACCOUNT_ID= # Stripe Connect account for x402 payments
                             # onboard at os.archive.energy

# ── Sentient ───────────────────────────────────────────────────────────
SENTIENT_OWNER_KEY=          # generated at first boot — full control
SENTIENT_API_KEY=            # public read key — share with consumers
SENTIENT_BASE_URL=           # self-hosted: your deployment URL
