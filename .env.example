# ── Rivet ─────────────────────────────────────────────────────────────
RIVET_TOKEN=
RIVET_PROJECT_ID=

# ── Inference Keys ─────────────────────────────────────────────────────
# Names must match ${VAR_NAME} references in AGENTS.md models: block.

ANTHROPIC_API_KEY=           # models.actor — Anthropic direct
                             # https://console.anthropic.com → API keys

EMBEDDING_API_KEY=           # models.embedding — OpenRouter recommended
                             # https://openrouter.ai → API keys
                             # default model: baai/bge-m3

HARNESS_KEY=                 # models.sandbox — OpenCode Zen API key
                             # https://opencode.ai/auth → copy API key
                             # default model: claude-opus-4-6

# ── Fixed Infrastructure ────────────────────────────────────────────────
# Sandbox: Daytona
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=          # your Daytona server URL

# Ingest: Parallel Systems (optional)
PARALLEL_SYSTEMS_API_KEY=
PARALLEL_SYSTEMS_WEBHOOK_SECRET=

# Ingest: Exa (optional)
EXA_API_KEY=

# Auth: Unkey (optional — required for public API)
UNKEY_ROOT_KEY=

# ── Telegram ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # @BotFather → /newbot

# ── GitHub (optional) ──────────────────────────────────────────────────
GITHUB_TOKEN=                # fine-grained PAT for PR creation

# ── Parse.bot (optional) ───────────────────────────────────────────────
PARSE_API_KEY=               # parse.bot API key for skill creation

# ── Sentient ───────────────────────────────────────────────────────────
SENTIENT_OWNER_KEY=          # generated at first boot — full control
SENTIENT_API_KEY=            # public read key — share with consumers
SENTIENT_BASE_URL=           # self-hosted: your deployment URL
